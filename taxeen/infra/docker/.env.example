# ============================================
# Taxeen Environment Configuration
# Copy this file to .env and update values
# ============================================

# -------------------------------------------
# Environment
# -------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=INFO

# -------------------------------------------
# PostgreSQL Database
# -------------------------------------------
POSTGRES_USER=taxeen
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_DB=taxeen
POSTGRES_PORT=5432

# -------------------------------------------
# Redis Cache/Queue
# -------------------------------------------
REDIS_PASSWORD=CHANGE_THIS_TO_SECURE_REDIS_PASSWORD
REDIS_PORT=6379

# -------------------------------------------
# Backend (FastAPI)
# -------------------------------------------
# JWT Configuration
JWT_SECRET=CHANGE_THIS_TO_YOUR_JWT_SECRET_KEY_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AES-256 Encryption Key (32 bytes, base64 encoded)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_THIS_TO_32_BYTE_ENCRYPTION_KEY

# CORS Origins (comma-separated)
CORS_ORIGINS=https://taxeen.com,https://www.taxeen.com

# -------------------------------------------
# Frontend (Flask)
# -------------------------------------------
FLASK_SECRET_KEY=CHANGE_THIS_TO_YOUR_FLASK_SECRET_KEY
SESSION_TYPE=redis

# -------------------------------------------
# SSL/TLS Configuration
# -------------------------------------------
SSL_CERT_PATH=/etc/nginx/ssl/taxeen.crt
SSL_KEY_PATH=/etc/nginx/ssl/taxeen.key

# -------------------------------------------
# Email Configuration (Optional)
# -------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@taxeen.com
SMTP_PASSWORD=CHANGE_THIS_SMTP_PASSWORD
SMTP_FROM=noreply@taxeen.com

# -------------------------------------------
# Payment Gateway (Paystack)
# -------------------------------------------
PAYSTACK_SECRET_KEY=sk_live_CHANGE_THIS
PAYSTACK_PUBLIC_KEY=pk_live_CHANGE_THIS
PAYSTACK_WEBHOOK_SECRET=CHANGE_THIS_WEBHOOK_SECRET

# -------------------------------------------
# Monitoring (Optional)
# -------------------------------------------
SENTRY_DSN=
GRAFANA_PASSWORD=admin
